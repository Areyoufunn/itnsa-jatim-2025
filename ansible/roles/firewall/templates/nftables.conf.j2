#!/usr/sbin/nft -f
# LKS 2025 – nftables ruleset untuk fw.itnsa.id
# Interface names: WAN, INT, DMZ, MGMT (renamed via udev)

flush ruleset

define WAN  = WAN
define INT  = INT
define DMZ  = DMZ
define MGMT = MGMT

define NET_INT  = 10.10.10.0/24
define NET_DMZ  = 10.10.20.0/24
define IP_DNS   = 10.10.10.10
define IP_VRRP  = 10.10.20.100
define IP_MAIL  = 10.10.20.10
define IP_LDAP  = 10.10.10.10

table inet filter {

    chain input {
        type filter hook input priority 0; policy drop;

        # Allow loopback
        iif lo accept

        # Allow established/related
        ct state established,related accept

        # Allow semua dari MGMT
        iif $MGMT accept

        # Allow ICMP
        ip protocol icmp accept

        # Allow SSH (jangan diubah – dilarang soal)
        tcp dport 22 accept

        # Allow WireGuard VPN
        iif $WAN udp dport {{ wg_port }} accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;

        # Allow established/related
        ct state established,related accept

        # INT dan DMZ bisa akses internet
        iif $INT oif $WAN accept
        iif $DMZ oif $WAN accept

        # VPN client (wg0) bisa akses INT dan DMZ
        iif wg0 oif $INT accept
        iif wg0 oif $DMZ accept

        # Mail server boleh query LDAP
        iif $DMZ oif $INT ip saddr $IP_MAIL ip daddr $IP_LDAP tcp dport 389 accept

        # Port forward: internet → VRRP (HAProxy)
        iif $WAN oif $DMZ ip daddr $IP_VRRP tcp dport { 80, 443 } accept

        # Port forward: internet → DNS
        iif $WAN oif $INT ip daddr $IP_DNS tcp dport 53 accept
        iif $WAN oif $INT ip daddr $IP_DNS udp dport 53 accept
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}

table ip nat {

    chain prerouting {
        type nat hook prerouting priority -100;

        # DNAT port 80/443 → VRRP
        iif $WAN tcp dport { 80, 443 } dnat to $IP_VRRP

        # DNAT port 53 → DNS
        iif $WAN tcp dport 53 dnat to $IP_DNS
        iif $WAN udp dport 53 dnat to $IP_DNS
    }

    chain postrouting {
        type nat hook postrouting priority 100;

        # Masquerade NAT ke internet
        oif $WAN masquerade
    }
}
