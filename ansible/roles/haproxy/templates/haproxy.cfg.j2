global
    log /dev/log local0
    maxconn 2000
    daemon

defaults
    log     global
    mode    http
    timeout connect 5s
    timeout client  50s
    timeout server  50s

# Frontend – HTTP redirect ke HTTPS
frontend http_in
    bind *:80
    redirect scheme https code 301

# Frontend – HTTPS dengan TLS termination
frontend https_in
    bind *:443 ssl crt /etc/haproxy/certs/web.pem
    http-response set-header via-proxy {{ ansible_hostname }}
    default_backend web_servers

# Backend – Load balance ke nginx port 8080
backend web_servers
    balance roundrobin
    server web01 {{ ip_web01 }}:8080 check
    server web02 {{ ip_web02 }}:8080 check
